# GıyBet — ortam değişkenleri (kopyala: .env.local veya Vercel Environment Variables)

# ── Supabase (zorunlu) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin moderasyon (zorunlu prod) ──────────────────────────────────
# Virgülle ayrılmış admin e-postaları — /admin/moderation erişimi
ADMIN_EMAILS=admin@example.com

# ── E-posta bildirimi (opsiyonel — yeni şikayet) ─────────────────────
# RESEND_API_KEY=
# ADMIN_NOTIFY_EMAIL=admin@example.com
# RESEND_FROM=GıyBet <onboarding@resend.dev>

# ── Harita / mekan arama (opsiyonel) ───────────────────────────────
# GOOGLE_PLACES_API_KEY=
# TOMTOM_API_KEY=
# NEXT_PUBLIC_TOMTOM_KEY=

# ── Capacitor mobil (APK) ───────────────────────────────────────────
# Varsayılan: https://giy-bet.vercel.app (capacitor.config.ts)
# CAPACITOR_SERVER_URL=https://giy-bet.vercel.app

# ── Seed scriptleri (yalnızca geliştirme) ────────────────────────────
# SEED_EMAIL=
# SEED_PASSWORD=
